# Firebase Admin SDK Configuration
# Get your service account JSON from: https://console.firebase.google.com/project/rentroof-bcfaf/settings/serviceaccounts/adminsdk

# For local development, you can either:
# 1. Set FIREBASE_SERVICE_ACCOUNT_JSON to your full service account JSON string
# 2. Or let Firebase Admin SDK use Application Default Credentials

# Option 1: Inline JSON (for CI/CD, not recommended for local development)
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}'

# Option 2: Use Application Default Credentials (for local development)
# 1. Install gcloud: https://cloud.google.com/sdk/docs/install
# 2. Run: gcloud auth application-default login
# 3. Select your Firebase project
# Then the backend will automatically use the credentials from your gcloud login

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8001
