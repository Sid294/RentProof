rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* ── Landing page waitlist signups ── */
    match /signups/{docId} {
      allow read:   if false;
      allow create: if request.resource.data.email is string
                    && request.resource.data.email.size() > 4
                    && request.resource.data.email.matches('.*@.*\\..*')
                    && request.resource.data.plan in ['starter', 'growth', 'pro']
                    && request.resource.data.source == 'landing';
    }

    /* ── Properties ── */
    match /properties/{propId} {
      allow read, update, delete: if request.auth != null
        && (
          resource.data.userId == request.auth.uid ||
          resource.data.landlordUid == request.auth.uid
        );
      allow create: if request.auth != null
        && (
          request.resource.data.userId == request.auth.uid ||
          request.resource.data.landlordUid == request.auth.uid
        );
    }

    /* ── Maintenance ── */
    match /maintenance/{requestId} {
      allow read, update, delete: if request.auth != null
        && (
          resource.data.userId == request.auth.uid ||
          resource.data.landlordUid == request.auth.uid
        );
      allow create: if request.auth != null
        && (
          request.resource.data.userId == request.auth.uid ||
          request.resource.data.tenantUid == request.auth.uid ||
          request.resource.data.landlordUid == request.auth.uid
        );
    }

    /* ── Deposits ── */
    match /deposits/{depositId} {
      allow read, update, delete: if request.auth != null
        && (
          resource.data.userId == request.auth.uid ||
          resource.data.landlordUid == request.auth.uid
        );
      allow create: if request.auth != null
        && (
          request.resource.data.userId == request.auth.uid ||
          request.resource.data.landlordUid == request.auth.uid
        );
    }

    /* ── Units ── */
    match /units/{unitId} {
      /* Landlord full access */
      allow read, update, delete: if request.auth != null
        && request.auth.uid == resource.data.landlordUid;
      allow create: if request.auth != null
        && request.resource.data.landlordUid == request.auth.uid;

      /* Tenant reads their own linked unit */
      allow read: if request.auth != null
        && request.auth.uid == resource.data.tenantUid;

      /* Tenant claims an unclaimed unit via invite.
         Only tenantUid / tenantName / tenantEmail may be written. */
      allow update: if request.auth != null
        && resource.data.tenantUid == null
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['tenantUid', 'tenantName', 'tenantEmail'])
        && request.resource.data.tenantUid == request.auth.uid;
    }

    /* ── Payments (landlord-managed) ── */
    match /payments/{paymentId} {
      allow read, update, delete: if request.auth != null
        && request.auth.uid == resource.data.landlordUid;
      allow create: if request.auth != null
        && request.resource.data.landlordUid == request.auth.uid;

      /* Tenant reads payment records for their own unit */
      allow read: if request.auth != null
        && exists(/databases/$(database)/documents/units/$(resource.data.unitId))
        && get(/databases/$(database)/documents/units/$(resource.data.unitId)).data.tenantUid
             == request.auth.uid;
    }

    /* ── Invites ── */
    match /invites/{token} {
      /* Token is the secret — anyone who has it can read it */
      allow read: if true;

      allow create: if request.auth != null
        && request.resource.data.landlordUid == request.auth.uid;

      /* Tenant marks invite as used.
         Only usedAt / tenantUid may be written. */
      allow update: if request.auth != null
        && resource.data.usedAt == null
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['usedAt', 'tenantUid'])
        && request.resource.data.tenantUid == request.auth.uid;
    }

    /* ── Maintenance requests ── */
    match /maintenance_requests/{reqId} {
      /* Landlord and the submitting tenant can both read */
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.landlordUid ||
        request.auth.uid == resource.data.tenantUid
      );

      /* Only the tenant can create; status must start as 'open' */
      allow create: if request.auth != null
        && request.resource.data.tenantUid == request.auth.uid
        && request.resource.data.status == 'open';

      /* Only the landlord can update; only status / updatedAt may change */
      allow update: if request.auth != null
        && request.auth.uid == resource.data.landlordUid
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['status', 'updatedAt']);
    }

    /* Deny everything else */
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
